<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- لون تعبئة الكرت الداخلي: زجاجي شبه شفاف 8% -->
    <solid android:color="#140D0D2B" />
    
    <!-- حدود ذهبية ناعمة 20% شفافية -->
    <stroke
        android:width="1.2dp"
        android:color="#33FFD700" />
        
    <!-- انحناء زوايا معتدل لتطابق معايير التصميم -->
    <corners android:radius="16dp" />
    
</shape>

<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- خلفية بنفسجية داكنة بشفافية 60% -->
    <solid android:color="#994A1A6B"/>
    <!-- حد بنفسجي ساطع بشفافية 80% -->
    <stroke android:width="1.2dp" android:color="#CC7F1CD8"/>
    <!-- زوايا دائرية 16dp عدا أسفل اليمين (0dp) لفقاعة المرسل الحالي -->

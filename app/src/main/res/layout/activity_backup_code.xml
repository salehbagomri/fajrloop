<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071B">

    <com.bagomri.fajrloop.ui.widget.AnimatedGradientView
        android:id="@+id/animated_gradient_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:layoutDirection="rtl"
        android:textDirection="rtl"
        android:scrollbarSize="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="40dp">

            <!-- شريط العنوان -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:padding="8dp"
                    android:contentDescription="رجوع"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="كود الطوارئ الاحتياطي"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

            <!-- حالة لست عضواً في حلقة -->
            <LinearLayout
                android:id="@+id/layout_no_halqa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="40dp"
                android:visibility="gone"
                tools:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_circle_warning"
                    app:tint="#6B6B8A"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أنت لست عضواً في أي حلقة حالياً لإنتاج أكواد طوارئ."
                    android:textSize="15sp"
                    android:textColor="#B0B0C5"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:layout_marginBottom="24dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_return_home"
                    android:layout_width="200dp"
                    android:layout_height="50dp"
                    android:text="العودة للرئيسية"
                    android:textSize="15sp"
                    android:textColor="#07071B"
                    android:textStyle="bold"
                    app:backgroundTint="#FFD700"
                    app:cornerRadius="12dp"
                    android:elevation="0dp" />

            </LinearLayout>

            <!-- حالة وجود حلقة -->
            <LinearLayout
                android:id="@+id/layout_has_halqa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <com.bagomri.fajrloop.ui.widget.GlassCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="كود الطوارئ اليومي"
                            android:textSize="12sp"
                            android:textColor="#B0B0C5"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_halqa_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="حلقة: أصدقاء الفجر"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="16dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#25254A"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="إذا كان صديقك يرن منبهه ولا يملك اتصال إنترنت، اقرأ له هذا الكود عبر مكالمة هاتفية لإيقاف منبهه:"
                            android:textSize="14sp"
                            android:textColor="#B0B0C5"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginBottom="24dp" />

                        <!-- كود الـ TOTP الكبير المميز بوهج ذهبي وزر النسخ -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_code_container"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:layout_marginBottom="24dp">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <!-- كود الطوارئ ممركز -->
                                <TextView
                                    android:id="@+id/text_totp_code"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="589 649"
                                    android:textSize="34sp"
                                    android:textColor="#FFD700"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.1"
                                    android:fontFamily="monospace"
                                    android:layout_centerInParent="true" />

                                <!-- زر النسخ التفاعلي على اليمين (RTL End) -->
                                <ImageView
                                    android:id="@+id/btn_copy_code"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_copy"
                                    android:padding="10dp"
                                    app:tint="#FFD700"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:layout_alignParentEnd="true"
                                    android:layout_centerVertical="true"
                                    android:contentDescription="نسخ الكود" />

                            </RelativeLayout>
                        </FrameLayout>

                        <!-- تفاصيل الصلاحية -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/image_totp_status_icon"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_circle_warning"
                                app:tint="#B0B0C5" />

                            <TextView
                                android:id="@+id/text_totp_status_desc"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="هذا الكود ينشط تلقائياً ولمدة 30 دقيقة فقط فور دخول وقت أذان الفجر اليوم."
                                android:textSize="13sp"
                                android:textColor="#B0B0C5"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                    </LinearLayout>
                </com.bagomri.fajrloop.ui.widget.GlassCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>

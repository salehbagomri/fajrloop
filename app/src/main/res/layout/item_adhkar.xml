<?xml version="1.0" encoding="utf-8"?>
<!--
    item_adhkar.xml — بطاقة ذكر واحدة (التصميم المحسّن والمنسّق بشكل طبيعي)

    الهوية البصرية:
    - بطاقة Glassmorphism أنيقة
    - نص الذكر بحجم طبيعي ومريح للقراءة
    - عداد دائري تفاعلي بحجم متناسق وغير مبالغ فيه
    - ألوان ذهبية متسقة مع هوية التطبيق
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <com.bagomri.fajrloop.ui.widget.GlassCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- ═══════ نص الذكر ═══════ -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scrollbarSize="0dp"
                android:fadeScrollbars="true"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/text_dhikr_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="اللَّهُ لَا إِلَٰهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ"
                    android:textColor="#F0FFFFFF"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />
            </ScrollView>

            <!-- فاصل ذهبي -->
            <View
                android:layout_width="40dp"
                android:layout_height="1.5dp"
                android:background="@color/gold"
                android:alpha="0.4"
                android:layout_marginBottom="16dp" />

            <!-- عدد التكرار المطلوب -->
            <TextView
                android:id="@+id/text_dhikr_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="التكرار المطلوب: 3 مرات"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- ═══════ العداد الدائري التفاعلي ═══════ -->
            <FrameLayout
                android:id="@+id/btn_counter_tap"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_circle_icon"
                android:backgroundTint="#22FFD700"
                android:clickable="true"
                android:focusable="true"
                android:clipToOutline="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:id="@+id/text_counter_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="#FFD700"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:includeFontPadding="false" />
            </FrameLayout>

            <!-- تلميح النقر -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👆"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  انقر على الدائرة لعد التكرار"
                    android:textColor="#50FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </com.bagomri.fajrloop.ui.widget.GlassCardView>

</LinearLayout>

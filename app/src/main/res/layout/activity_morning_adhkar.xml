<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071B"
    android:layoutDirection="rtl">

    <com.bagomri.fajrloop.ui.widget.AnimatedGradientView
        android:id="@+id/animated_gradient_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- عنوان علوي -->
    <TextView
        android:id="@+id/text_adhkar_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌅 أذكار الصباح"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- مؤشر الصفحة (مثال: 1 / 10) -->
    <TextView
        android:id="@+id/text_page_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 / 10"
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/text_adhkar_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_adhkar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/text_page_indicator"
        app:layout_constraintBottom_toTopOf="@id/btn_close_adhkar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- زر الإغلاق -->
    <Button
        android:id="@+id/btn_close_adhkar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="إنهاء الأذكار 🌅"
        android:textColor="#07071B"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#FFD700"
        app:cornerRadius="12dp"
        android:stateListAnimator="@null"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

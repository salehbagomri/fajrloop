<?xml version="1.0" encoding="utf-8"?>
<!--
    item_permission_row.xml — صف صلاحية واحدة
    يُستخدم في شاشة PermissionSetupActivity
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#131B2A"
    app:cardCornerRadius="12dp"
    app:strokeColor="#1E293B"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- أيقونة الحالة -->
        <ImageView
            android:id="@+id/icon_status"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_circle_check"
            android:contentDescription="حالة الصلاحية"
            android:layout_marginEnd="12dp" />

        <!-- نص الصلاحية -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_permission_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اسم الصلاحية"
                android:textSize="15sp"
                android:textColor="#E6EDF3"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/text_permission_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="وصف الصلاحية"
                android:textSize="12sp"
                android:textColor="#6E7681"
                android:fontFamily="sans-serif"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- زر الإجراء -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="منح"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:backgroundTint="#1A3A5C"
            app:cornerRadius="8dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

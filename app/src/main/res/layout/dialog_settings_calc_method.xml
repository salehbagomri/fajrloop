<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_glass"
    android:padding="20dp"
    android:layoutDirection="rtl">

    <!-- مقبض السحب السفلي للـ BottomSheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#33FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- العنوان رئيسي -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="طريقة حساب مواقيت الصلاة"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="اختر الطريقة المعتمدة في مدينتك لضبط مواقيت الأذان والمنبه بدقة:"
        android:textColor="#B0B0C5"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <!-- قائمة الطرق المتاحة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 1. أم القرى -->
        <LinearLayout
            android:id="@+id/btn_method_um_al_qura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🕋"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="جامعة أم القرى (مكة المكرمة)"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الطريقة الرسمية للمملكة العربية السعودية واليمن"
                    android:textColor="#6B6B8A"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/check_um_al_qura"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="✓"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 2. رابطة العالم الإسلامي -->
        <LinearLayout
            android:id="@+id/btn_method_muslim_league"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🌐"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="رابطة العالم الإسلامي"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="معتمدة في أوروبا ومعظم الدول الإسلامية والعالمية"
                    android:textColor="#6B6B8A"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/check_muslim_league"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="✓"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 3. الهيئة المصرية العامة للمساحة -->
        <LinearLayout
            android:id="@+id/btn_method_egypt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🇪🇬"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الهيئة المصرية العامة للمساحة"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تعتمد زاوية الفجر 19.5 درجة، وتستخدم بمصر وشمال أفريقيا"
                    android:textColor="#6B6B8A"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/check_egypt"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="✓"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 4. كراتشي -->
        <LinearLayout
            android:id="@+id/btn_method_karachi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🇵🇰"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="جامعة العلوم الإسلامية بكراتشي"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="معتمدة في شبه القارة الهندية والباكستان وأفغانستان"
                    android:textColor="#6B6B8A"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/check_karachi"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="✓"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 5. أمريكا الشمالية -->
        <LinearLayout
            android:id="@+id/btn_method_isna"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🇺🇸"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الجمعية الإسلامية لأمريكا الشمالية (ISNA)"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تعتمد زاوية الفجر 15.0 درجة، وتستخدم بأمريكا وكندا"
                    android:textColor="#6B6B8A"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/check_isna"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="✓"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

    <!-- زر إغلاق -->
    <TextView
        android:id="@+id/btn_close_calc"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="تراجع"
        android:textColor="#6B6B8A"
        android:textSize="14sp"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>

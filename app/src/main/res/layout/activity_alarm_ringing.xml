<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_alarm_ringing.xml — شاشة رنين المنبه (التصميم الاحترافي المُطوَّر)

    الهوية البصرية:
    - خلفية بنفسجية-نيفي داكنة متدرجة
    - لهجة ذهبية (#E8D5A3 / #FFD700)
    - Glassmorphism للبطاقات
    - تسلسل بصري واضح: الوقت → المسجد → التحدي → التأكيد
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_gradient"
    tools:context=".ui.alarm.AlarmRingingActivity">

    <!-- طبقة Glassmorphism الخلفية -->
    <View
        android:id="@+id/glassLayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_glass_overlay"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- دوائر زخرفية في الخلفية -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_mosque_glow"
        android:alpha="0.06"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-60dp"
        android:layout_marginStart="-60dp" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_mosque_glow"
        android:alpha="0.04"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-40dp"
        android:layout_marginEnd="-40dp" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:fitsSystemWindows="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="56dp"
            android:paddingBottom="32dp">

            <!-- ══════════════════════════════════════════════ -->
            <!--  القسم العلوي: تسمية الصلاة + الوقت + الأيقونة -->
            <!-- ══════════════════════════════════════════════ -->

            <!-- شريط علوي: تسمية الصلاة -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_challenge_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕌"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/text_alarm_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="صلاة الفجر"
                    android:textSize="14sp"
                    android:textColor="#CCE8D5A3"
                    android:letterSpacing="0.05"
                    android:layout_marginStart="6dp"
                    tools:text="صلاة الفجر" />
            </LinearLayout>

            <!-- عرض الوقت الكبير -->
            <TextView
                android:id="@+id/text_alarm_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="88sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:layout_marginTop="8dp"
                android:letterSpacing="-0.03"
                tools:text="04:32" />

            <!-- نص توجيهي -->
            <TextView
                android:id="@+id/text_subheading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حان وقت صلاة الفجر"
                android:textSize="14sp"
                android:textColor="#66FFFFFF"
                android:gravity="center"
                android:layout_marginTop="2dp" />

            <!-- حاوية الأيقونة مع الهالة -->
            <FrameLayout
                android:id="@+id/container_mosque"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="16dp">

                <View
                    android:id="@+id/view_mosque_glow"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_mosque_glow" />

                <ImageView
                    android:id="@+id/image_mosque"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mosque"
                    android:contentDescription="أيقونة الفجر" />
            </FrameLayout>

            <!-- ══════════════════════════════════════════════ -->
            <!--  بطاقة التحدي الرئيسية                        -->
            <!-- ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/card_challenge_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_challenge_card"
                android:padding="24dp"
                android:layout_marginTop="20dp">

                <!-- رأس البطاقة -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/text_challenge_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تحدي الاستيقاظ"
                        android:textSize="18sp"
                        android:textColor="@color/gold"
                        android:textStyle="bold"
                        android:letterSpacing="0.02" />

                    <View
                        android:layout_width="48dp"
                        android:layout_height="2dp"
                        android:background="@color/gold"
                        android:alpha="0.5"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/text_challenge_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حل التحدي لتفعيل إيقاف الرنين"
                        android:textSize="12sp"
                        android:textColor="#80FFFFFF"
                        android:gravity="center" />
                </LinearLayout>

                <!-- ─── 1. تحدي الحساب ─── -->
                <LinearLayout
                    android:id="@+id/layout_challenge_math"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <!-- إطار المسألة -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_challenge_input"
                        android:gravity="center"
                        android:padding="20dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/text_math_question"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24 + 13 = ?"
                            android:textSize="38sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            tools:text="24 + 13 = ?" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/input_math_answer"
                        android:layout_width="180dp"
                        android:layout_height="56dp"
                        android:inputType="numberSigned"
                        android:background="@drawable/bg_challenge_input"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:hint="الإجابة"
                        android:textColorHint="#40FFFFFF"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btn_submit_math"
                        android:layout_width="180dp"
                        android:layout_height="52dp"
                        android:text="تحقق ✓"
                        android:textSize="16sp"
                        android:textColor="#0A0520"
                        android:textStyle="bold"
                        android:background="@drawable/bg_btn_gold_capsule"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- ─── 2. تحدي الهز ─── -->
                <LinearLayout
                    android:id="@+id/layout_challenge_shake"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_shake"
                        android:contentDescription="هز الهاتف"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/text_shake_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 30"
                        android:textSize="48sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <ProgressBar
                        android:id="@+id/progress_shake"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="30"
                        android:progress="0"
                        android:progressTint="@color/gold"
                        android:progressBackgroundTint="#1AFFFFFF" />
                </LinearLayout>

                <!-- ─── 3. تحدي الكلمات ─── -->
                <LinearLayout
                    android:id="@+id/layout_challenge_word"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="رتّب الحروف لتكوين كلمة"
                        android:textSize="12sp"
                        android:textColor="#66FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <!-- إطار الحروف المبعثرة -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_challenge_input"
                        android:gravity="center"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/text_scrambled_letters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ج ر ف"
                            android:textSize="36sp"
                            android:textColor="@color/gold_glow"
                            android:textStyle="bold"
                            android:letterSpacing="0.3" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/input_word_answer"
                        android:layout_width="220dp"
                        android:layout_height="56dp"
                        android:inputType="text"
                        android:background="@drawable/bg_challenge_input"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:hint="أدخل الكلمة"
                        android:textColorHint="#40FFFFFF"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btn_submit_word"
                        android:layout_width="180dp"
                        android:layout_height="52dp"
                        android:text="تحقق ✓"
                        android:textSize="16sp"
                        android:textColor="#0A0520"
                        android:textStyle="bold"
                        android:background="@drawable/bg_btn_gold_capsule"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- ─── زر الغفوة ─── -->
                <Button
                    android:id="@+id/btn_snooze"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="غفوة (متبقي: 2) ⏰"
                    android:textSize="14sp"
                    android:textColor="@color/gold"
                    android:textStyle="bold"
                    android:background="@drawable/bg_challenge_input"
                    android:stateListAnimator="@null"
                    android:visibility="gone" />

                <!-- ══════════════════════════════════════════════ -->
                <!--  قسم تأكيد الاستيقاظ (يظهر بعد حل التحدي)   -->
                <!-- ══════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/layout_waiting_confirmation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <!-- بطاقة النجاح العلوية -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_challenge_input"
                        android:padding="20dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎉"
                            android:textSize="40sp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تم حل التحدي بنجاح!"
                            android:textSize="18sp"
                            android:textColor="@color/green"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/text_waiting_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="بانتظار تأكيد استيقاظك من زميلك المسؤول..."
                            android:textSize="13sp"
                            android:textColor="#AAFFFFFF"
                            android:gravity="center"
                            android:lineSpacingExtra="4dp" />

                        <ProgressBar
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:indeterminateTint="@color/gold"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>

                    <!-- زر اتصل بالمسؤول -->
                    <Button
                        android:id="@+id/btn_call_partner"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="📞  اتصل بالمسؤول للحصول على الرمز"
                        android:textSize="14sp"
                        android:textColor="@color/gold"
                        android:textStyle="bold"
                        android:background="@drawable/bg_challenge_input"
                        android:stateListAnimator="@null"
                        android:layout_marginBottom="12dp" />

                    <!-- فاصل -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#20FFFFFF"
                        android:layout_marginBottom="16dp" />

                    <!-- تعليمات TOTP -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أدخل رمز الاستيقاظ الاحتياطي (TOTP):"
                        android:textSize="12sp"
                        android:textColor="#AAFFFFFF"
                        android:layout_marginBottom="8dp" />

                    <!-- حقل TOTP + زر -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/input_totp_code"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="52dp"
                            android:inputType="number"
                            android:maxLength="7"
                            android:background="@drawable/bg_challenge_input"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:hint="123 456"
                            android:textColorHint="#40FFFFFF"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btn_submit_totp"
                            android:layout_width="100dp"
                            android:layout_height="52dp"
                            android:text="تحقق"
                            android:textSize="14sp"
                            android:textColor="#0A0520"
                            android:textStyle="bold"
                            android:background="@drawable/bg_btn_gold_capsule"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <!-- فاصل -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#20FF6B6B"
                        android:layout_marginBottom="12dp" />

                    <!-- زر SOS -->
                    <Button
                        android:id="@+id/btn_sos"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="🚨  لا أستطيع الاستيقاظ — استغاثة"
                        android:textSize="14sp"
                        android:textColor="@color/red"
                        android:textStyle="bold"
                        android:background="@drawable/bg_btn_sos"
                        android:stateListAnimator="@null" />

                </LinearLayout>

            </LinearLayout>
            <!-- نهاية card_challenge_panel -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

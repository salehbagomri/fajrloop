<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_alarm_ringing.xml — شاشة رنين المنبه (التصميم النهائي المقيّد)

    المنطق الأمني:
    - لا يوجد أي زر لإيقاف المنبه أثناء مرحلة التحدي.
    - لا يوجد زر تجاوز يدوي — الإيقاف يتم فقط عبر:
      1. تأكيد المسؤول سحابياً (Firebase).
      2. إدخال رمز TOTP من المسؤول.
      3. زر استغاثة (يُرسل حالة panic للحلقة).
    - NestedScrollView لدعم التمرير عند ظهور الكيبورد.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_gradient"
    tools:context=".ui.alarm.AlarmRingingActivity">

    <!-- طبقة Glassmorphism الخلفية -->
    <View
        android:id="@+id/glassLayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_glass_overlay"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="50dp"
            android:paddingBottom="40dp">

            <!-- تسمية «صلاة الفجر» -->
            <TextView
                android:id="@+id/text_alarm_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="صلاة الفجر"
                android:textSize="20sp"
                android:textColor="#B0E8D5A3"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.15"
                android:layout_marginTop="20dp"
                tools:text="صلاة الفجر" />

            <!-- عرض الوقت — الرقم الكبير المهيب -->
            <TextView
                android:id="@+id/text_alarm_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="80sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="sans-serif-thin"
                android:includeFontPadding="false"
                android:layout_marginTop="4dp"
                tools:text="04:32" />

            <!-- حاوية الأيقونة مع الهالة -->
            <FrameLayout
                android:id="@+id/container_mosque"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="16dp">

                <View
                    android:id="@+id/view_mosque_glow"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_mosque_glow" />

                <ImageView
                    android:id="@+id/image_mosque"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mosque"
                    android:contentDescription="أيقونة الفجر" />
            </FrameLayout>

            <!-- نص توجيهي -->
            <TextView
                android:id="@+id/text_subheading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حان وقت صلاة الفجر\nاستيقظ وأدِّ صلاتك"
                android:textSize="15sp"
                android:textColor="#80FFFFFF"
                android:gravity="center"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />

            <!-- ═══════════════════ بطاقة التحديات ═══════════════════ -->
            <LinearLayout
                android:id="@+id/card_challenge_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_challenge_card"
                android:padding="24dp"
                android:layout_marginTop="24dp">

                <TextView
                    android:id="@+id/text_challenge_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تحدي الاستيقاظ"
                    android:textSize="17sp"
                    android:textColor="@color/gold"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="1.5dp"
                    android:background="#40E8D5A3"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/text_challenge_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="حل التحدي لتفعيل إيقاف الرنين"
                    android:textSize="12sp"
                    android:textColor="#99FFFFFF"
                    android:layout_marginBottom="20dp" />

                <!-- 1. تحدي الحساب -->
                <LinearLayout
                    android:id="@+id/layout_challenge_math"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/text_math_question"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24 + 13 = ?"
                        android:textSize="32sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="16dp" />

                    <EditText
                        android:id="@+id/input_math_answer"
                        android:layout_width="160dp"
                        android:layout_height="52dp"
                        android:inputType="numberSigned"
                        android:background="@drawable/bg_challenge_input"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:hint="الإجابة"
                        android:textColorHint="#50FFFFFF"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btn_submit_math"
                        android:layout_width="160dp"
                        android:layout_height="48dp"
                        android:text="تحقق ✓"
                        android:textSize="15sp"
                        android:textColor="#0A0520"
                        android:textStyle="bold"
                        android:background="@drawable/bg_btn_gold_capsule"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- 2. تحدي الهز -->
                <LinearLayout
                    android:id="@+id/layout_challenge_shake"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_shake"
                        android:contentDescription="هز الهاتف"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/text_shake_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 30"
                        android:textSize="36sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <ProgressBar
                        android:id="@+id/progress_shake"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="16dp"
                        android:max="30"
                        android:progress="0"
                        android:progressTint="@color/gold"
                        android:progressBackgroundTint="#20FFFFFF" />
                </LinearLayout>

                <!-- 3. تحدي الكلمات -->
                <LinearLayout
                    android:id="@+id/layout_challenge_word"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/text_scrambled_letters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ج ر ف"
                        android:textSize="32sp"
                        android:textColor="@color/gold_glow"
                        android:textStyle="bold"
                        android:letterSpacing="0.4"
                        android:layout_marginBottom="16dp" />

                    <EditText
                        android:id="@+id/input_word_answer"
                        android:layout_width="200dp"
                        android:layout_height="52dp"
                        android:inputType="text"
                        android:background="@drawable/bg_challenge_input"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:hint="أدخل الكلمة"
                        android:textColorHint="#50FFFFFF"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btn_submit_word"
                        android:layout_width="160dp"
                        android:layout_height="48dp"
                        android:text="تحقق ✓"
                        android:textSize="15sp"
                        android:textColor="#0A0520"
                        android:textStyle="bold"
                        android:background="@drawable/bg_btn_gold_capsule"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- زر الغفوة (Snooze) -->
                <Button
                    android:id="@+id/btn_snooze"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="غفوة (متبقي: 2) ⏰"
                    android:textSize="14sp"
                    android:textColor="@color/gold"
                    android:textStyle="bold"
                    android:background="@drawable/bg_challenge_input"
                    android:stateListAnimator="@null"
                    android:visibility="gone" />

                <!-- ═══════════════════ شاشة تأكيد الاستيقاظ ═══════════════════ -->
                <LinearLayout
                    android:id="@+id/layout_waiting_confirmation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:indeterminateTint="@color/gold"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تم حل التحدي بنجاح! 🎉"
                        android:textSize="17sp"
                        android:textColor="@color/green"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/text_waiting_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="بانتظار تأكيد استيقاظك من زميلك المسؤول..."
                        android:textSize="13sp"
                        android:textColor="#AAFFFFFF"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="16dp" />

                    <!-- زر اتصال بالمسؤول -->
                    <Button
                        android:id="@+id/btn_call_partner"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="📞  اتصل بالمسؤول للحصول على الرمز"
                        android:textSize="13sp"
                        android:textColor="@color/gold"
                        android:background="@drawable/bg_challenge_input"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:stateListAnimator="@null"
                        android:layout_marginBottom="24dp" />

                    <!-- خط فاصل -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#20FFFFFF"
                        android:layout_marginBottom="20dp" />

                    <!-- حقل إدخال رمز طوارئ TOTP -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أدخل رمز الاستيقاظ الاحتياطي (TOTP):"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="24dp">

                        <EditText
                            android:id="@+id/input_totp_code"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="48dp"
                            android:inputType="number"
                            android:maxLength="7"
                            android:background="@drawable/bg_challenge_input"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:hint="123 456"
                            android:textColorHint="#40FFFFFF"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btn_submit_totp"
                            android:layout_width="100dp"
                            android:layout_height="48dp"
                            android:text="تحقق"
                            android:textSize="13sp"
                            android:textColor="#0A0520"
                            android:textStyle="bold"
                            android:background="@drawable/bg_btn_gold_capsule"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <!-- خط فاصل -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#15FF6B6B"
                        android:layout_marginBottom="16dp" />

                    <!-- زر الاستغاثة SOS (يظهر فقط بعد حل التحدي) -->
                    <Button
                        android:id="@+id/btn_sos"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="🚨  لا أستطيع الاستيقاظ — استغاثة"
                        android:textSize="14sp"
                        android:textColor="@color/red"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_btn_sos"
                        android:stateListAnimator="@null" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

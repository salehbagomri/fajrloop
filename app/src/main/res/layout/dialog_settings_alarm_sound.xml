<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_glass"
    android:padding="20dp"
    android:layoutDirection="rtl">

    <!-- مقبض السحب السفلي للـ BottomSheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#33FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- عنوان رئيسي -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="صوت المنبه المفضل"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="اختر الأذان أو النغمة المفضلة للاستيقاظ لصلاة الفجر:"
        android:textColor="#B0B0C5"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <!-- الخيارات -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 1. أذان مشاري العفاسي -->
        <LinearLayout
            android:id="@+id/btn_sound_afasy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕌"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/text_sound_afasy"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="الأذان بصوت الشيخ مشاري العفاسي"
                android:textColor="#B0B0C5"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_preview_afasy"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="#E8D5A3"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="معاينة" />
        </LinearLayout>

        <!-- 2. أذان عبدالباسط -->
        <LinearLayout
            android:id="@+id/btn_sound_abdulbasit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕌"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/text_sound_abdulbasit"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="الأذان بصوت الشيخ عبدالباسط عبدالصمد"
                android:textColor="#B0B0C5"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_preview_abdulbasit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="#E8D5A3"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="معاينة" />
        </LinearLayout>

        <!-- 3. نغمة إسلامية هادئة -->
        <LinearLayout
            android:id="@+id/btn_sound_islamic"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/text_sound_islamic"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="نغمة إسلامية هادئة وجذابة"
                android:textColor="#B0B0C5"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_preview_islamic"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="#E8D5A3"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="معاينة" />
        </LinearLayout>

        <!-- 4. نغمة النظام الافتراضية -->
        <LinearLayout
            android:id="@+id/btn_sound_default"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_code_container"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/text_sound_default"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="نغمة النظام الافتراضية"
                android:textColor="#B0B0C5"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_preview_default"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="#E8D5A3"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="معاينة" />
        </LinearLayout>
    </LinearLayout>

    <!-- زر حفظ التعديل -->
    <Button
        android:id="@+id/btn_save_sound"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="حفظ التعديل"
        android:textColor="#07071B"
        android:textStyle="bold"
        android:backgroundTint="#FFD700"
        android:layout_marginBottom="12dp"
        app:cornerRadius="12dp" />

    <!-- زر إغلاق -->
    <TextView
        android:id="@+id/btn_close_sound"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="تراجع"
        android:textColor="#6B6B8A"
        android:textSize="14sp"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>

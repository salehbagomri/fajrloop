<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_glass"
    android:padding="20dp"
    android:layoutDirection="rtl">

    <!-- مقبض السحب السفلي للـ BottomSheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#33FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- عنوان رئيسي -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تحدي الاستيقاظ المفضل"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="اختر نوع التحدي ومستوى الصعوبة لإطفاء رنين المنبه:"
        android:textColor="#B0B0C5"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <!-- 1. نوع التحدي (Challenge Type) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="نوع التحدي"
        android:textColor="#FFD700"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        android:weightSum="3">

        <!-- تحدي الحساب -->
        <LinearLayout
            android:id="@+id/btn_type_math"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_code_container"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧮"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/text_type_math"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حل معادلة"
                android:textColor="#B0B0C5"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- تحدي الكتابة -->
        <LinearLayout
            android:id="@+id/btn_type_word"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_code_container"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✍️"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/text_type_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اكتب الكلمة"
                android:textColor="#B0B0C5"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- تحدي الهز -->
        <LinearLayout
            android:id="@+id/btn_type_shake"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_code_container"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/text_type_shake"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="رج الهاتف"
                android:textColor="#B0B0C5"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- 2. مستوى الصعوبة (Difficulty Level) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="مستوى الصعوبة"
        android:textColor="#FFD700"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        android:weightSum="3">

        <!-- سهل -->
        <LinearLayout
            android:id="@+id/btn_diff_easy"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_code_container"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/text_diff_easy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سهل"
                android:textColor="#B0B0C5"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- متوسط -->
        <LinearLayout
            android:id="@+id/btn_diff_medium"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_code_container"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/text_diff_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="متوسط"
                android:textColor="#B0B0C5"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- صعب -->
        <LinearLayout
            android:id="@+id/btn_diff_hard"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_code_container"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/text_diff_hard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="صعب"
                android:textColor="#B0B0C5"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- زر حفظ التعديل -->
    <Button
        android:id="@+id/btn_save_challenge"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="حفظ التعديل"
        android:textColor="#07071B"
        android:textStyle="bold"
        android:backgroundTint="#FFD700"
        android:layout_marginBottom="12dp"
        app:cornerRadius="12dp" />

    <!-- زر إغلاق -->
    <TextView
        android:id="@+id/btn_close_challenge"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="تراجع"
        android:textColor="#6B6B8A"
        android:textSize="14sp"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>

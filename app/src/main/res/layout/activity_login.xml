<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_gradient"
    tools:context=".ui.auth.LoginActivity">

    <!-- خلفية النجوم المتلألئة أو طبقة التنعيم -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#20000000" />

    <!-- الشعار والاسم -->
    <LinearLayout
        android:id="@+id/layout_logo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_google_signin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="48dp">

        <!-- مسجد مذهب مقتبس من ic_mosque -->
        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/ic_mosque"
            android:tint="#E8D5A3"
            android:contentDescription="شعار التطبيق"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="حلقة الفجر"
            android:textSize="40sp"
            android:textColor="#E8D5A3"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FajrLoop"
            android:textSize="18sp"
            android:textColor="#8B949E"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="«استيقظوا لصلاة الفجر معاً بالمسؤولية المتبادلة»"
            android:textSize="14sp"
            android:textColor="#A8B2C1"
            android:fontFamily="sans-serif"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

    <!-- زر تسجيل الدخول بواسطة جوجل -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_google_signin"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="تسجيل الدخول بواسطة Google"
        android:textSize="16sp"
        android:textColor="#0D1117"
        android:fontFamily="sans-serif-medium"
        app:icon="@drawable/ic_google"
        app:iconTint="@null"
        app:iconGravity="textStart"
        app:iconSize="24dp"
        app:iconPadding="16dp"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="32dp"
        android:layout_marginStart="36dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="48dp"
        app:strokeColor="#15FFFFFF"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/layout_logo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- مؤشر الانتظار المتطور -->
    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminateTint="#E8D5A3"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

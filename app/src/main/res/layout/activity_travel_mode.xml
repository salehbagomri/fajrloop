<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/app-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071B">

    <com.bagomri.fajrloop.ui.widget.AnimatedGradientView
        android:id="@+id/animated_gradient_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:layoutDirection="rtl"
        android:textDirection="rtl"
        android:scrollbarSize="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="40dp">

            <!-- شريط العنوان -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:padding="8dp"
                    android:contentDescription="رجوع"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="وضع السفر والطوارئ"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

            <!-- كرت الشرح -->
            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ما هو وضع السفر والطوارئ؟"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تفعيل هذا الوضع يُعفيك مؤقتاً من رنين المنبه ومسؤولية إيقاظ الأصدقاء. يُعاد ترتيب الحلقة تلقائياً لتخطي حسابك لكي لا تنكسر الحلقة أثناء سفرك أو نومك الاضطراري."
                        android:textSize="13sp"
                        android:textColor="#B0B0C5"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- كرت التفعيل -->
            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تفعيل وضع السفر"
                            android:textSize="15sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_travel_switch_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الوضع غير نشط حالياً"
                            android:textSize="12sp"
                            android:textColor="#B0B0C5"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_travel_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:theme="@style/Theme.FajrLoop.Switch" />

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- كرت تحديد المدة (يظهر عند التفعيل) -->
            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:id="@+id/card_duration_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حدد مدة السفر:"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <RadioGroup
                        android:id="@+id/radio_group_duration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- حتى التمكين اليدوي -->
                        <RadioButton
                            android:id="@+id/radio_indefinite"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="حتى التمكين اليدوي"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="8dp"
                            android:buttonTint="#FFD700" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="سيبقى وضع السفر نشطاً حتى تقوم بإلغائه يدوياً."
                            android:textSize="12sp"
                            android:textColor="#B0B0C5"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="16dp" />

                        <!-- يوم واحد -->
                        <RadioButton
                            android:id="@+id/radio_1_day"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="لمدة يوم واحد"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="8dp"
                            android:buttonTint="#FFD700" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ينتهي تلقائياً بعد 24 ساعة."
                            android:textSize="12sp"
                            android:textColor="#B0B0C5"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="16dp" />

                        <!-- 3 أيام -->
                        <RadioButton
                            android:id="@+id/radio_3_days"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="لمدة 3 أيام"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="8dp"
                            android:buttonTint="#FFD700" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ينتهي تلقائياً بعد 3 أيام."
                            android:textSize="12sp"
                            android:textColor="#B0B0C5"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="16dp" />

                        <!-- أسبوع -->
                        <RadioButton
                            android:id="@+id/radio_7_days"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="لمدة أسبوع"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="8dp"
                            android:buttonTint="#FFD700" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ينتهي تلقائياً بعد 7 أيام."
                            android:textSize="12sp"
                            android:textColor="#B0B0C5"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="16dp" />

                        <!-- تاريخ مخصص -->
                        <RadioButton
                            android:id="@+id/radio_custom"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="تحديد تاريخ مخصص"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="8dp"
                            android:buttonTint="#FFD700" />

                        <TextView
                            android:id="@+id/text_custom_date_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="اختر تاريخاً محدداً لعودتك."
                            android:textSize="12sp"
                            android:textColor="#B0B0C5"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="8dp" />

                    </RadioGroup>

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- زر الحفظ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="حفظ الإعدادات"
                android:textSize="16sp"
                android:textColor="#07071B"
                android:textStyle="bold"
                app:backgroundTint="#FFD700"
                app:cornerRadius="16dp"
                android:elevation="0dp"
                tools:ignore="UnusedAttribute" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>

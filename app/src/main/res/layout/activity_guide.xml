<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071B">

    <com.bagomri.fajrloop.ui.widget.AnimatedGradientView
        android:id="@+id/animated_gradient_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:layoutDirection="rtl"
        android:textDirection="rtl"
        android:scrollbarSize="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="40dp">

            <!-- شريط العنوان -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:padding="8dp"
                    android:contentDescription="رجوع"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="دليل استخدام حلقة الفجر"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

            <!-- كرت الترحيب -->
            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مرحباً بك في FajrLoop! 🕌"
                        android:textSize="18sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="التطبيق الثوري المعتمد على المسؤولية الجماعية لضمان استيقاظك واستيقاظ أصدقائك لصلاة الفجر في جماعة يومياً."
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- 1. الفكرة الأساسية للتطبيق -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 الفكرة الأساسية للتطبيق"
                android:textSize="12sp"
                android:textColor="#B0B0C5"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="القانون الذهبي للمنبه"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="لا يمكنك إيقاف منبهك بنفسك نهائياً! بمجرد رنين المنبه، يجب عليك حل تحدي التحقق لتخفيف الصوت، ولكن المنبه لن يتوقف نهائياً حتى يقوم صديقك المسؤول عنك في الحلقة بتأكيد استيقاظك."
                        android:textSize="13sp"
                        android:textColor="#B0B0C5"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- 2. السلسلة الدائرية والمسؤولية -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄 السلسلة الدائرية والمسؤولية"
                android:textSize="12sp"
                android:textColor="#B0B0C5"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="كيف يتم توزيع المهام؟"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="يعتمد التطبيق على المسؤولية الدائرية (Loop). أ مسؤول عن ب، وب مسؤول عن ج، وج مسؤول عن أ. في حال الحلقة من عضوين، تكون المسؤولية ثنائية متبادلة مباشرة."
                        android:textSize="13sp"
                        android:textColor="#B0B0C5"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- 3. وضع الطوارئ والسيناريوهات الاستثنائية -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 وضع الطوارئ والسيناريوهات الاستثنائية"
                android:textSize="12sp"
                android:textColor="#B0B0C5"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ماذا لو عجزت عن الاستيقاظ؟"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="زر &quot;لا أستطيع الاستيقاظ&quot;: يخفف المنبه ويرسل إشعار استغاثة سحابي عاجل لجميع أعضاء الحلقة. كود الطوارئ (TOTP): كود أمان متغير لدى صديقك، يمكنك إدخاله لإيقاف منبهك عند انقطاع الإنترنت."
                        android:textSize="13sp"
                        android:textColor="#B0B0C5"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- 4. المعالجة السحابية والتصعيد الذكي -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☁️ المعالجة السحابية والتصعيد الذكي"
                android:textSize="12sp"
                android:textColor="#B0B0C5"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ماذا يحدث إذا لم يستجب العضو؟"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="بعد 5 دقائق: تنبيه للصديق المسؤول مباشرة. بعد 15 دقيقة: تصعيد لجميع الأعضاء. بعد 30 دقيقة: يتم إيقاف المنبه تلقائياً ويسجل العضو في قائمة &quot;فاته الفجر&quot;."
                        android:textSize="13sp"
                        android:textColor="#B0B0C5"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- 5. الموقع الجغرافي ووضع السفر -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✈️ الموقع الجغرافي ووضع السفر"
                android:textSize="12sp"
                android:textColor="#B0B0C5"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.bagomri.fajrloop.ui.widget.GlassCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="المزايا الجغرافية والتكيف"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تحديث GPS لضبط مواقيت الأذان. وضع السفر: تعطيل المنبه 1-7 أيام دون الإضرار بالحلقة."
                        android:textSize="13sp"
                        android:textColor="#B0B0C5"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.bagomri.fajrloop.ui.widget.GlassCardView>

            <!-- آية الختام -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="«وتعاونوا على البر والتقوى» 🤝🌙"
                android:textSize="16sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:textAlignment="center"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>

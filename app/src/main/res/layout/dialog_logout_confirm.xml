<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_glass"
    android:padding="24dp"
    android:layoutDirection="rtl"
    android:gravity="center">

    <!-- أيقونة التحذير الدائرية الخفيفة -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_circle_icon"
        android:backgroundTint="#1AFF6B6B"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚪"
            android:textSize="24sp"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- عنوان الحوار -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تسجيل الخروج"
        android:textColor="#FFD700"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <!-- نص الوصف -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="هل أنت متأكد من رغبتك في تسجيل الخروج من التطبيق؟ سيتم مسح بيانات المزامنة المؤقتة محلياً."
        android:textColor="#B0B0C5"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <!-- أزرار الإجراءات -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- زر تراجع -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="إلغاء"
            android:textColor="#B0B0C5"
            android:textSize="14sp"
            android:textStyle="bold"
            app:strokeColor="#40B0B0C5"
            app:strokeWidth="1dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- زر تأكيد الخروج -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="خروج"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#FF6B6B"
            app:cornerRadius="12dp"
            android:layout_marginStart="6dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>

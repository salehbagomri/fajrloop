<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_glass"
    android:padding="24dp"
    android:layoutDirection="rtl"
    android:gravity="center">

    <!-- أيقونة تعبيرية -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_circle_icon"
        android:backgroundTint="#1A2ECC71"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤝"
            android:textSize="24sp"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- عنوان الحوار -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="انضمام لحلقة"
        android:textColor="#FFD700"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- نص الوصف -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="أدخل كود الدعوة المكون من 4 رموز (مثال: FJR-A8B9) للانضمام لحلقة صديقك."
        android:textColor="#B0B0C5"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- حقل كود الدعوة -->
    <EditText
        android:id="@+id/input_invite_code"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_challenge_input"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:hint="FJR-A8B9"
        android:textColorHint="#40FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center"
        android:maxLines="1"
        android:singleLine="true"
        android:layout_marginBottom="24dp" />

    <!-- أزرار الإجراءات -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- زر تراجع -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="إلغاء"
            android:textColor="#B0B0C5"
            android:textSize="14sp"
            android:textStyle="bold"
            app:strokeColor="#40B0B0C5"
            app:strokeWidth="1dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- زر تأكيد الانضمام -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_weight="1.4"
            android:layout_height="48dp"
            android:text="انضمام للحلقة 🤝"
            android:textColor="#07071B"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#FFD700"
            app:cornerRadius="12dp"
            android:layout_marginStart="6dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Thin (100) -->
    <font
        android:fontStyle="normal" android:fontWeight="100"
        android:font="@font/pp_nm_arabic_thin"
        app:fontStyle="normal" app:fontWeight="100"
        app:font="@font/pp_nm_arabic_thin" />

    <!-- Light (300) -->
    <font
        android:fontStyle="normal" android:fontWeight="300"
        android:font="@font/pp_nm_arabic_light"
        app:fontStyle="normal" app:fontWeight="300"
        app:font="@font/pp_nm_arabic_light" />

    <!-- Book / Regular-Light (350) -->
    <font
        android:fontStyle="normal" android:fontWeight="350"
        android:font="@font/pp_nm_arabic_book"
        app:fontStyle="normal" app:fontWeight="350"
        app:font="@font/pp_nm_arabic_book" />

    <!-- Regular (400) -->
    <font
        android:fontStyle="normal" android:fontWeight="400"
        android:font="@font/pp_nm_arabic_regular"
        app:fontStyle="normal" app:fontWeight="400"
        app:font="@font/pp_nm_arabic_regular" />

    <!-- Medium (500) -->
    <font
        android:fontStyle="normal" android:fontWeight="500"
        android:font="@font/pp_nm_arabic_medium"
        app:fontStyle="normal" app:fontWeight="500"
        app:font="@font/pp_nm_arabic_medium" />

    <!-- SemiBold (600) -->
    <font
        android:fontStyle="normal" android:fontWeight="600"
        android:font="@font/pp_nm_arabic_semibold"
        app:fontStyle="normal" app:fontWeight="600"
        app:font="@font/pp_nm_arabic_semibold" />

    <!-- Bold (700) -->
    <font
        android:fontStyle="normal" android:fontWeight="700"
        android:font="@font/pp_nm_arabic_bold"
        app:fontStyle="normal" app:fontWeight="700"
        app:font="@font/pp_nm_arabic_bold" />

</font-family>
